     .agents-tab-item.active { background: transparent; }  /* no active hint */
 
     /* Cover (cloned into tab-item by JS — see setupAgentsMobile).
-       Full-bleed: width 100vw, no border-radius, runs to viewport edges. */
+       True full-bleed: width: 100vw alone is NOT enough — the cover is
+       a child of .agents-tab-item which itself sits in a container
+       chain (.agents-tabs-v → .agents-side → .agents-stage). Each
+       container has its own x-offset (~18 px from viewport edge), so a
+       `width: 100vw` cover starts AT the parent's x and overflows the
+       right side. Use the desktop "bleed-out" trick (same as
+       .play-carousel margin: calc(50% - 50vw)) — negative margins
+       cancel the parent's x-offset and pull the cover back to x=0,
+       making it true edge-to-edge regardless of how nested the
+       container is. */
     .agents-tab-item .agents-card-cover {
+      position: relative;
       width: 100vw;
       max-width: 100vw;
-      margin: 0 0 18px;
+      margin-left:  calc(50% - 50vw);
+      margin-right: calc(50% - 50vw);
+      margin-top: 0;
+      margin-bottom: 18px;
       border-radius: 0;
       aspect-ratio: 3 / 2;
     }
