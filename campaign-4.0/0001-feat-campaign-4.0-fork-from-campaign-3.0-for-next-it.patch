+      display: flex;
+      gap: 8px;
+      justify-content: center;
+      margin-top: 18px;
+      padding: 0 16px;
+    }
+    .play-dots .dot {
+      width: 6px;
+      height: 6px;
+      border-radius: 50%;
+      background: rgba(10, 10, 16, 0.22);
+      transition: background .2s, transform .2s;
+    }
+    .play-dots .dot.active {
+      background: var(--text);
+      transform: scale(1.25);
+    }
