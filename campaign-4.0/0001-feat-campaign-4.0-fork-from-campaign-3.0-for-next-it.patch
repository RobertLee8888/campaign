+<!-- ============================================================ CARD-DETAIL MODAL
+     A lightbox-style overlay that anchors the enlarged card to where
+     the user clicked it. JS sets CSS variables (--cd-x, --cd-y,
+     --cd-init-scale, --cd-target-w) on .cd-anchor; CSS animation
+     grows the cloned card from its source rect to the target size
+     with a 3D dip-then-rise. After the card lands, the share methods
+     stagger in on the right.
+     ============================================================ -->
+<div class="modal" id="modal-card-detail" aria-hidden="true">
+  <!-- Mobile-only close button. Desktop relies on backdrop click to
+       close, but on mobile the .cd-anchor stretches to nearly the full
+       viewport (it gets transform: translate(-50%, -50%) + flex column)
+       so there's no real backdrop left to click. Hidden by base CSS,
+       revealed in the mobile @media block. data-close hooks into the
+       generic modal closer (document.body click listener). -->
+  <button class="cd-close" type="button" data-close aria-label="Close card detail">
+    <i class="ph-bold ph-x" aria-hidden="true"></i>
+  </button>
+  <div class="cd-stage" id="cd-stage">
+    <div class="cd-anchor" id="cd-anchor">
