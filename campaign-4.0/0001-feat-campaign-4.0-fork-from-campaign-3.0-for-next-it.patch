+      const s = document.createElement('span');
+      s.className = 'separator';
+      s.textContent = ch;
+      return s;
+    }
+    // Format a number with comma separators, return array of {type:'d'|'s',val}
+    function format(n) {
+      const digits = String(n);
+      const parts = [];
+      for (let i = 0; i < digits.length; i++) {
+        parts.push({ type: 'd', val: digits[i] });
+        const fromRight = digits.length - 1 - i;
+        if (fromRight > 0 && fromRight % 3 === 0) {
+          parts.push({ type: 's', val: ',' });
+        }
+      }
+      return parts;
+    }
