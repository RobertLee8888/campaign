+    /* Play tabs were 9px 12px + 12.5 font ≈ 30 h tap target — below
+       the 36 secondary-touch floor. With the round-46 copy update
+       lengthening some labels ("Backtest win rates", "Signals &
+       alerts"), the row now scrolls horizontally anyway, so we can
+       safely make each tap target larger without breaking layout. */
+    .play-tab { padding: 11px 14px; font-size: 13px; min-height: 38px; }
+    .play-tab i { font-size: 12px; }
+    .play-tab.active::after { left: 14px; right: 14px; }
+
+    /* Bleed the carousel to viewport edges (desktop already does this
+       via the same margin trick). Without this the carousel inherits
+       the section's content-box and the peek card cannot bleed past
+       the section's inner padding — which is the "not reaching the
+       edge" feel the user reported. */
+    .play-carousel {
+      margin-left:  calc(50% - 50vw);
+      margin-right: calc(50% - 50vw);
+      width: 100vw;
+    }
+    .play-track {
+      gap: 16px;
+      /* Apple Music / Spotify / Material 3 idiom: first card is LEFT-
+         ALIGNED (not centered). padding-left = 16 anchors the first
+         card to the viewport's logical inset; the next card's peek
+         bleeds all the way to the viewport's RIGHT edge, where
+         section overflow:hidden clips it as a hard edge — not a soft
+         fade. The previous `scroll-snap-align: center` produced a 48-
+         px empty gutter on the left that looked like the carousel
+         was inset from the viewport, defeating the bleed. */
+      padding-left: 16px;
+      padding-right: 16px;
+      scroll-padding-left: 16px;
+      scroll-padding-right: 16px;
+      padding-bottom: 16px;
+      scroll-snap-type: x mandatory;
+    }
+    .play-card {
+      /* Card 329 wide on a 393 viewport (calc 100vw - 64). After the
+         left-snap, neighbour card starts at 16+329+16 = 361, and 32
+         px of it is visible before viewport overflow:hidden clips at
+         x=393 — the peek hits the actual screen edge, not a padding
+         boundary. */
+      flex: 0 0 calc(100vw - 64px);
+      max-width: 380px;
+      scroll-snap-align: start;
+      scroll-snap-stop: always;
+    }
