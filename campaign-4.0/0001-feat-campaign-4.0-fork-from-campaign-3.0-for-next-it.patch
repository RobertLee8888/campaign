+     new positions immediately on swap so the numbers stay
+     anchored to position, not to row.
+     ============================================================ */
+  (() => {
+    const rowsEl = document.getElementById('lb-rows');
+    if (!rowsEl) return;
+    const DURATION = 600;
+    const EASING   = 'cubic-bezier(.22, 1, .36, 1)';
+
+    function shuffleStep() {
+      // Skip if user is hovering the table (would yank a row out from
+      // under the cursor) or if the page tab isn't visible.
+      if (document.hidden) return;
+      if (rowsEl.matches(':hover')) return;
+      const rows = [...rowsEl.children];
+      if (rows.length < 2) return;
+
+      // Pick a random adjacent pair
+      const i = Math.floor(Math.random() * (rows.length - 1));
+      const upper = rows[i];       // currently at position i
+      const lower = rows[i + 1];   // currently at position i+1
+
+      // FIRST — capture current visual positions
+      const upperTop = upper.getBoundingClientRect().top;
+      const lowerTop = lower.getBoundingClientRect().top;
+
+      // SWAP — put lower BEFORE upper in the DOM
+      rowsEl.insertBefore(lower, upper);
+
+      // Update rank labels to reflect the NEW position order
+      [...rowsEl.children].forEach((r, idx) => {
+        const idxEl = r.querySelector('.idx');
