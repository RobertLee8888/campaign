+      if (digitChars.length !== stacks.length) {
+        render(false);
+        return;
+      }
+      stacks.forEach((stack, i) => {
+        const d = parseInt(digitChars[i], 10);
+        stack.style.transform = `translateY(-${d * DIGIT_HEIGHT}px)`;
+      });
+    }
