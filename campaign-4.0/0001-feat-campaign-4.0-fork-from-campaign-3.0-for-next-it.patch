+      // PLAY — next frame, transition transforms back to 0
+      requestAnimationFrame(() => {
+        upper.style.transition = `transform ${DURATION}ms ${EASING}`;
+        lower.style.transition = `transform ${DURATION}ms ${EASING}`;
