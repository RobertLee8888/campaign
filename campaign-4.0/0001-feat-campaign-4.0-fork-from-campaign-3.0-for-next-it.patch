+    /* ---------------------------------------------------------- */
+    /* Touch target floor pulled up to Apple HIG / WCAG 2.5.8 (44 CSS
+       px). The previous values (.nav-cta 7/10 → 27 h, .nav-tab 0/8 →
+       34 w) were below threshold on the page's primary conversion
+       button — a measurable mis-tap rate hit. Reference comparison:
+       Linear ships 32 h pills on a 64 h nav (similar density); we
+       split the difference at 40 h since the CTA carries an icon. */
+    .nav-inner { padding: 0 12px; gap: 8px; }
+    .brand-text { display: none; }              /* free up width for CTA + toggle */
+
+    /* Tabs and ghost CTA both relocate INTO the drawer below — they
+       are NOT deleted, just moved. The previous mobile rule kept the
+       tabs as icon-only inline, but with the drawer pattern below we
+       finally have somewhere to put labelled rows (better discovery
+       than icon-only icons that users have to guess at). */
+    .nav-tabs { display: none; }
+    .nav-cta-ghost { display: none; }
+
+    /* Primary "Test any FinTwit Trader" CTA stays inline — it's the
+       single most important action on the page and a sticky bottom
+       bar reinforces it elsewhere. Touch target floor pulled up to
+       Apple HIG (44 CSS px) / WCAG 2.5.8. */
+    .nav-cta {
+      padding: 11px 16px;                       /* 7/10 → 11/16 */
+      font-size: 13px;
+      gap: 6px;
+      min-height: 40px;
+    }
+    .nav-cta i { font-size: 14px; }
+
+    /* Reveal the hamburger and turn on the drawer. */
+    .nav-menu-toggle { display: inline-grid; place-items: center; }
+    .nav-drawer { display: flex; }              /* override base display:none */
+
+    /* ---------------------------------------------------------- */
+    /* S1 · OPENING (hero)                                        */
+    /* ---------------------------------------------------------- */
+    /* Tighter padding + smaller H1 so the headline + sub + arrow
+       fit one viewport on a 390-class phone without crowding. */
+    .opening { padding: 76px 16px 56px; min-height: 100svh; }
+    .opening-content { max-width: 100%; padding: 0 4px; position: relative; }
+    /* H1 pushed from clamp(28, 8vw, 38) — i.e. 31px on 393w — up to
+       clamp(36, 9.5vw, 44) so the headline lands at 37px on a 393
+       canvas, hitting the mobile hero H1 spec (36-40). Reference:
+       Linear lands at 40px, Anthropic ~48px, Vercel floors at 24
+       (extreme). Alva tracks Linear's density. */
+    .opening h1 {
+      font-size: clamp(36px, 9.5vw, 44px);
+      margin: 0 0 22px;
+      /* Halo collapsed from 6 stacked text-shadows (one as large as
+         0 0 170px #fff) down to 2. The original 6-layer recipe was
+         needed when the H1 was tiny (31px) and the float-tweet cards
+         could bleed through; with the H1 now ~37px and the cards also
+         pushed further out (see .float-tweet below), 2 layers is
+         enough. The visual back-plate is now a radial-gradient pseudo
+         (see ::before) — single GPU layer instead of 6, saves ~15ms
+         per repaint on mid-tier ARM. */
+      text-shadow: 0 0 24px #fff, 0 0 60px #fff;
+      position: relative;
+    }
+    .opening h1::before {
+      content: '';
+      position: absolute;
+      inset: -32px -20px;
+      background: radial-gradient(ellipse 70% 55% at center, #fff 30%, transparent 75%);
+      z-index: -1;
+      pointer-events: none;
+    }
+    .opening h1 .line-handle { margin-top: 0.24em; }
+    .opening h1 .line-2      { margin-top: 0.22em; }
+    .handle-roller {
+      text-shadow:
+        0 0  8px #ffffff,
+        0 0 16px #ffffff,
+        0 0 30px #ffffff,
+        0 0 52px #ffffff;
+    }
+    .handle-roller::after {
+      text-shadow:
+        0 0  8px #ffffff,
+        0 0 16px #ffffff,
+        0 0 30px #ffffff;
+    }
+    .opening-sub {
+      font-size: clamp(15px, 4.6vw, 19px);
+      margin: 0 auto 28px;
+      line-height: 1.4;
+      text-shadow:
+        0 0  10px #ffffff,
+        0 0  22px #ffffff,
+        0 0  42px #ffffff,
+        0 0  72px #ffffff,
+        0 0 110px #ffffff;
+    }
+    .opening-arrow { width: 48px; height: 48px; }
+    .opening-arrow::after { inset: 2px; }
+    .opening-arrow i { font-size: 22px; }
+    /* Drop tweet card density — 4 cards is enough texture without
+       crowding the H1. They're also smaller so the H1 reads cleanly. */
+    .float-tweet {
+      width: 184px !important;
+      font-size: 10.5px !important;
+      padding: 0.75em 0.9em !important;
+    }
+    .float-tweet.tier-near { width: 220px !important; font-size: 12px !important; }
+    .float-tweet.tier-far  { width: 164px !important; font-size: 10px !important; }
+    /* Hero float-tweet visibility on mobile.
+       PREVIOUS rule was `:nth-child(n+5) { display: none }` — kept the
+       first 4 cards (HTML order 1-4). But those 4 are all in the upper
+       half of the section (y = 32 / 18 / 4 / 38 %), leaving the bottom
+       half of the viewport blank — user reported "下面一半屏幕都是白色,
+       看不到后面飘的卡片".
+       Fix: hide-all + handpick 7 cards whose --y values cover the full
+       vertical range (4 % → 92 %) without crowding the H1 zone
+       (~30-55 % is where the headline + sub sit). Card y-distribution:
+         #3  y=4%   top edge
+         #2  y=18%  upper third
+         #4  y=38%  H1 left flank
+         #7  y=56%  below sub
+         #15 y=68%  mid-low
+         #11 y=78%  lower third
+         #8  y=92%  bottom edge */
+    .opening-bg .float-tweet { display: none !important; }
+    .opening-bg .float-tweet:nth-child(2),
+    .opening-bg .float-tweet:nth-child(3),
+    .opening-bg .float-tweet:nth-child(4),
+    .opening-bg .float-tweet:nth-child(7),
+    .opening-bg .float-tweet:nth-child(8),
+    .opening-bg .float-tweet:nth-child(11),
+    .opening-bg .float-tweet:nth-child(15) {
+      display: block !important;
+    }
+    /* (The WebGL lens canvas init is skipped on phones in JS, so this
+       rule is just a belt-and-braces hide.) */
+    .lens-canvas { display: none !important; }
+
+    /* ---------------------------------------------------------- */
+    /* S2 · STAGE MARQUEE                                         */
+    /* ---------------------------------------------------------- */
+    .stage.stage-marquee {
+      /* Desktop sets `display: flex; align-items: center` which on a
+         narrow viewport would put the headline + marquee side-by-side
+         as a row. Reset to block flow so the headline stacks ABOVE the
+         marquee and each piece gets full viewport width. */
+      display: block;
+      padding: 72px 0 72px;
+      min-height: auto;
+    }
+    /* The desktop plaque uses a 1250px-wide backdrop-filter mask that
+       engulfs the entire phone viewport on a 390-class screen — so the
+       marquee cards behind get blurred + dimmed to invisibility. On
+       phones we ditch the overlay entirely: the headline sits in the
+       normal flow above the marquee, and the cards stay sharp. */
+    .stage-marquee .stage-headline-overlay {
+      position: relative;
+      inset: auto;
+      display: block;
+      backdrop-filter: none;
+      -webkit-backdrop-filter: none;
+      -webkit-mask-image: none;
+              mask-image: none;
+      padding: 0 18px 28px;
+      pointer-events: auto;
+    }
+    .stage-marquee .stage-headline-overlay::before,
+    .stage-marquee .stage-headline-overlay::after { display: none; }
+    .stage-marquee .stage-headline-inner {
+      padding: 0;
+      max-width: 100%;
+    }
+    .stage-marquee .stage-headline-inner h1 {
+      max-width: 100%;
+      padding: 0;
+      /* Was clamp(22, 7vw, 30) = 27px on 393w — read like H2 not hero.
+         Pushed to clamp(28, 8.5vw, 36) so it lands at 33px on 393w,
+         in line with mobile stage spec (32-36). Linear /method
+         storytelling page H1 = 40 mobile; we stay a notch lower since
+         this is sub-hero copy, not the page entry. */
+      font-size: clamp(28px, 8.5vw, 36px);
+      line-height: 1.15;
+      letter-spacing: -0.02em;
+      display: block;
+    }
+    /* .stage-title-line set to nowrap on desktop so each clause stays on
+       one line within the headline column. On a phone the column is too
+       narrow for "FinTwit's 3,000+" and "most-followed accounts." to fit
+       — let them wrap naturally. */
+    .stage-marquee .stage-title-line { white-space: normal; }
+    .stage-marquee .stage-actions {
+      padding: 22px 0 0;
+      gap: 10px;
+    }
+    /* Stage actions: vertical stack full-width on mobile.
+       Reason: the round-46 copy update made the ghost CTA
+       "Can't find an Account?" (~23 char) — combined with the
+       primary "Check your following" (~21 char), the two buttons
+       at padding 14×22 + 14 font would exceed 470 px wide on a
+       393 viewport. flex-wrap on the parent helps avoid overflow
+       but produces an ugly mismatched-width pair on the second
+       row. Forcing column + stretch gives a clean stacked pair,
+       both 44 h with matching width — same idiom as the sticky
+       bottom CTA bar and the modal-card-detail share methods. */
+    .stage-marquee .stage-actions {
+      flex-direction: column;
+      align-items: stretch;
+      width: 100%;
+      max-width: 360px;
+    }
+    .stage-actions .btn-primary,
+    .stage-actions .btn-ghost {
+      width: 100%;
+      justify-content: center;
+      padding: 14px 22px;
+      font-size: 14px;
+      min-height: 44px;
+    }
+    /* Visual hierarchy for the 4-line stage H1: the last span has
+       `.stage-title-sub` (sub-line, set in the markup as the
+       "Updated every hour." closer). Desktop didn't ship a CSS
+       rule for it — fine on desktop because the line is short and
+       reads as a tail. On mobile, the lines wrap and the sub-line
+       feels visually equal weight to the main copy. Drop one
+       size + weight + alpha to restore the sub-line role. */
+    .stage-marquee .stage-title-sub {
+      font-size: 0.7em;           /* relative to the H1 — drops ~33→23 */
+      font-weight: 500;
+      opacity: 0.7;
+      display: block;
+      margin-top: 0.4em;
+    }
+    /* Marquee rows: smaller cards, tighter gap. */
+    .mq-card {
+      width: 196px;
+      height: 178px;
+      padding: 18px 14px 16px;
+      gap: 8px;
+      margin-right: 14px;
+    }
+    .mq-avatar { width: 44px; height: 44px; }
+    .mq-meta b { font-size: 14px; max-width: 160px; }
+    .mq-meta span { font-size: 12px; }       /* 10 → 12, caption floor */
+    .mq-v { font-size: 24px; }
+    .mq-l { font-size: 11px; }                /* 9 → 11, marquee label was
+                                                  illegible on the auto-scroll
+                                                  ROI cards; also matters under
+                                                  reduced-motion where the
+                                                  marquee stops dead and the
+                                                  label is the only ID hint */
+    .card-marquee { gap: 14px; }
+
+    /* ---------------------------------------------------------- */
+    /* S3 · LEADERBOARD                                           */
+    /* ---------------------------------------------------------- */
+    #leaderboard { padding-top: 80px; }
+    #leaderboard .section-head {
+      margin: 0 auto 56px;
+      padding: 0 6px;
+    }
+    #leaderboard .section-head h2 { font-size: clamp(26px, 7vw, 34px); }
+    /* lb-sub is the section's main subtitle (under H2). 14px is below
+       the 16px iOS body floor on a 393w canvas and reads as caption,
+       not lead-paragraph. Bumped to 16 — Linear & Anthropic both ship
+       16-17 for their hero/section subtitles on mobile. */
+    .lb-sub { font-size: 16px; line-height: 1.5; }
+    /* The aurora halo bleeds in from the section sides — at narrow widths
+       pull the inset in tight to the section edge so it sits behind the
+       lb-card cleanly instead of running off-canvas. */
+    #leaderboard::before {
+      top: 240px;
+      left: 0; right: 0;
+    }
+
+    /* Card chrome — toolbar, sort tabs, meta */
+    .lb-toolbar { padding: 12px 14px; gap: 10px; }
+    .sort-tabs  { gap: 4px; }                   /* 2 → 4, tap-spacing breathing */
+    .sort-tab   { padding: 8px 12px; font-size: 12px; min-height: 36px; }
+    /* Meta is a status line (refreshed time + ranked count) that informs
+       data freshness. 10px was unreadable in 4G-class glare; pulled to
+       12 (caption floor) and slightly tighter spacing. */
+    .lb-meta    { font-size: 12px; letter-spacing: 0.03em; }
+
+    /* Table grid: idx | creator | best ROI | risk pill.
+       Same column count for header AND rows so they align cleanly,
+       compact gaps + padding so 360-class phones don't horizontally
+       clip the ROI / Risk columns (the previous rule was row-only and
+       used a 350+ px grid that overflowed the 306 px content area). */
+    #leaderboard .lb-header,
+    #leaderboard .lb-row,
+    .lb-header,
+    .lb-row {
+      grid-template-columns: 22px minmax(0, 1fr) 58px 52px;
+      gap: 8px;
+      padding-left: 12px;
+      padding-right: 12px;
+    }
+    /* Header was 9.5px — that's the information architecture cue
+       (# / Creator / Best ROI / Risk) and it was illegible. Pulled to
+       11 (still below 12 floor because the header is structural cue
+       not body text — Coinbase Pro mobile uses 10-11 for the same
+       slot). If still tight we'll go to 12 in a follow-up. */
+    #leaderboard .lb-header,
+    .lb-header { padding-top: 11px; padding-bottom: 10px; font-size: 11px; }
+    #leaderboard .lb-row,
+    .lb-row    { padding-top: 12px; padding-bottom: 12px; }
+    #leaderboard .lb-header .hide-sm,
+    #leaderboard .lb-row .cell.hide-sm,
+    .lb-row .cell.hide-sm { display: none; }
+    #leaderboard .lb-row .who,
+    .lb-row .who { gap: 8px; }
+    #leaderboard .lb-row .who img,
+    .lb-row .who img { width: 30px; height: 30px; }
+    /* The .who flex container holds img + an unnamed wrapper div (b + span).
+       For the b/span ellipsis below to actually clip on a narrow phone
+       column, the wrapper div needs `min-width: 0; flex: 1; overflow: hidden`
+       so flex doesn't size it to intrinsic content width (otherwise the
+       long handle string blows past the column and overlaps the ROI cell). */
+    #leaderboard .lb-row .who > div,
+    .lb-row .who > div { min-width: 0; flex: 1; overflow: hidden; }
+    #leaderboard .lb-row .who b,
+    .lb-row .who b {
+      font-size: 13px;
+      white-space: nowrap;
+      overflow: hidden;
+      text-overflow: ellipsis;
+    }
+    #leaderboard .lb-row .who span,
+    .lb-row .who span {
+      /* Was 10.5 + nowrap+ellipsis — that dropped the tag silently
+         ("@RaoulGMI · Liquidity / crypto" became "@RaoulGMI · Liq…").
+         The tag is the user's mental anchor for what this creator
+         covers. Restored to 12 (caption floor) and allowed two lines
+         so handle + tag both stay readable. Reference: Coinbase Pro
+         leaderboard mobile uses the same wrap behaviour. */
+      font-size: 12px;
+      line-height: 1.35;
+      display: -webkit-box;
+      -webkit-line-clamp: 2;
+      -webkit-box-orient: vertical;
+      overflow: hidden;
+    }
+    #leaderboard .lb-row .cell .v,
+    .lb-row .cell .v { font-size: 13px; }     /* 12.5 → 13, value floor */
+    .lb-row .idx { font-size: 12px; }
+    /* Risk pill: was 9px font + 3/7 padding = unreadable. Pulled to
+       11/12 padding for proper tap silhouette (even though it's a
+       label, hit area matters for screen-readers / keyboard nav). */
+    .risk-pill   { padding: 4px 9px; font-size: 11px; letter-spacing: 0.04em; }
+
+    /* ---------------------------------------------------------- */
+    /* S4 · PLAYBOOK CAROUSEL                                     */
+    /* ---------------------------------------------------------- */
+    .section.section-playbook { padding: 76px 0 88px; overflow: hidden; }
+    .section-playbook .section-head {
+      margin: 0 18px 22px;
