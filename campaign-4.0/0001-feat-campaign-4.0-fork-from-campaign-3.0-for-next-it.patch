+    .play-card p { font-size: 16px; line-height: 1.5; margin-top: 20px; }
+    .play-card .play-cta {
+      margin-top: 18px;
+      padding: 14px 22px;                        /* 12 → 14, tap-height 38→44 */
+      font-size: 14px;                           /* 13 → 14 */
+      min-height: 44px;
+    }
+    .play-cover i { font-size: 64px; }
+
+    /* Carousel position indicator — Material 3 Hero Carousel requires
+       "Always show the position indicator" so the user knows there's
+       more than one card. Dots are CSS-only; JS wires the .active
+       class on scroll position (see end of file). */
