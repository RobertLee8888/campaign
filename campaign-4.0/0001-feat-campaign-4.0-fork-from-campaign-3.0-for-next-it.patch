+<script>
+  /* ============================================================
+     SCROLL RESTORATION — force every page-load (incl. refresh) to start
+     at the top of the page. Without this, the browser remembers the
+     previous scroll position and tries to restore it after first paint,
+     producing a visible flash of the first screen followed by a jump
+     to the saved position. Always-top is the cleanest fix.
+     ============================================================ */
+  if ('scrollRestoration' in history) {
+    history.scrollRestoration = 'manual';
+  }
+  // Defensive: force scroll to top before first paint in case the browser
+  // ignores the manual hint above (older Safari/iOS), and once more on the
+  // load event for any async layout shifts that re-position content.
+  window.scrollTo(0, 0);
+  addEventListener('load', () => window.scrollTo(0, 0));
+
+  /* ============================================================
+     SECTION 2 CARD-STACK HOVER — JS-driven for stability
+     Pure CSS :hover ~ siblings retriggered as moved cards slid under
+     the cursor (classic "jumping cards" bug). JS-managed instead:
+     mouseenter on any card adds .is-hovered + writes --push on each
+     sibling; mouseleave on the stack wipes both.
+     ============================================================ */
+  (() => {
+    const stack = document.querySelector('.card-stack');
+    if (!stack) return;
+    const cards = Array.from(stack.querySelectorAll('.perspective-wrap'));
+    const PUSH = 130;
+
+    cards.forEach((card, idx) => {
+      card.addEventListener('mouseenter', () => {
+        cards.forEach((c, i) => {
+          c.classList.toggle('is-hovered', i === idx);
+          if (i === idx)        c.style.setProperty('--push', '0px');
+          else if (i < idx)     c.style.setProperty('--push', -PUSH + 'px');
+          else                  c.style.setProperty('--push',  PUSH + 'px');
+        });
+      });
+    });
+    stack.addEventListener('mouseleave', () => {
+      cards.forEach(c => {
+        c.classList.remove('is-hovered');
+        c.style.removeProperty('--push');
+      });
+    });
+  })();
