+    function render(initial) {
+      const parts = format(value);
+      counter.innerHTML = '';
+      stacks.length = 0;
+      parts.forEach(p => {
+        if (p.type === 's') {
+          counter.appendChild(buildSeparator(p.val));
+        } else {
+          const { roller, stack } = buildRoller();
+          counter.appendChild(roller);
+          stacks.push(stack);
+        }
+      });
