diff --git a/campaign-4.0/index.html b/campaign-4.0/index.html
new file mode 100644
index 0000000..80fd7af
--- /dev/null
+++ b/campaign-4.0/index.html
@@ -0,0 +1,9417 @@
+<!doctype html>
+<html lang="en">
+<head>
+<meta charset="utf-8" />
+<meta name="viewport" content="width=device-width,initial-scale=1" />
+<title>ALVA · The FinTwit Alpha League — backtested rankings</title>
+<meta name="description" content="Alva backtests every public call from FinTwit's most-followed Traders and ranks them by real returns. Wins, misses, even deleted posts." />
+<!-- 3.0 round 6 — Brand-wide swap to Delight (9 weights, locally hosted).
+     Google Fonts links removed; Delight covers 100..900 so it replaces
+     all three previous families (Inter / Space Grotesk / JetBrains Mono).
+     3.0 round 10 — exception: the navbar wordmark uses Archivo Black
+     (heavy display logo font) for a distinct brand-mark feel.
+     Loaded via Google Fonts as a single-weight family. -->
+<link rel="preconnect" href="https://fonts.googleapis.com" />
+<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
+<!-- 3.0 round 11 — Wordmark font swapped Archivo Black → Big Shoulders
+     Display. Patric King's condensed American Gothic (Chicago Design
+     System lineage) gives the FinTwit Alpha League mark a stadium-
+     signage / editorial-poster character that Archivo Black's neutral
+     boldness lacked. -->
+<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&display=swap" rel="stylesheet" />
+<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" />
+<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css" />
+<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/fill/style.css" />
+
+<!-- Preload the 4 Delight weights that show above the fold (hero / sub
+     / nav / mono label). Skip Thin / ExtraLight / Light / Black — they
+     paint after first scroll. Saves ~600 ms LCP on mid-tier 4G because
+     the H1 character glyphs are ready by the time the H1 lays out
+     instead of swapping mid-paint. Reference: web.dev/optimize-lcp
+     (preload critical fonts is the #1 LCP fix for sites that ship
+     >2 webfont weights). -->
+<link rel="preload" as="font" type="font/ttf" href="./fonts/Delight-Regular.ttf"   crossorigin />
+<link rel="preload" as="font" type="font/ttf" href="./fonts/Delight-SemiBold.ttf"  crossorigin />
+<link rel="preload" as="font" type="font/ttf" href="./fonts/Delight-Bold.ttf"      crossorigin />
+<link rel="preload" as="font" type="font/ttf" href="./fonts/Delight-ExtraBold.ttf" crossorigin />
+
+<!-- Three.js — drives the opening section's cat-eye lens shader.
+     Loaded ONLY on PC widths. The lens shader is mobile-skipped in JS
+     (mobile gets DOM-only float-tweet cards), so we save the 670 KB
+     bundle on every mobile visit — a measurable LCP win (~1-2 s on
+     mid-tier 4G). Reference: web.dev "Below-the-fold-only JS should
+     be deferred or conditionally loaded". -->
+<script>
+  if (!window.matchMedia('(max-width: 760px)').matches) {
+    var s = document.createElement('script');
+    s.src = './three.min.js';
+    s.defer = true;
+    s.onerror = function () {
+      this.onerror = null;
+      var f = document.createElement('script');
+      f.src = 'https://unpkg.com/three@0.160.0/build/three.min.js';
+      f.defer = true;
+      document.head.appendChild(f);
+    };
+    document.head.appendChild(s);
+  }
+</script>
+<style>
+  /* ============================================================
+     DELIGHT — brand typeface, 9 weights, locally hosted.
+     Replaces Inter / Space Grotesk / JetBrains Mono. Same family name
+     across all weights so CSS just uses font-weight to pick the right
+     file. font-display: swap so text renders immediately with the
+     system fallback while the ttf finishes loading.
+     ============================================================ */
+  @font-face { font-family: 'Delight'; font-weight: 100; font-style: normal; font-display: swap; src: url('./fonts/Delight-Thin.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 200; font-style: normal; font-display: swap; src: url('./fonts/Delight-ExtraLight.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 300; font-style: normal; font-display: swap; src: url('./fonts/Delight-Light.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 400; font-style: normal; font-display: swap; src: url('./fonts/Delight-Regular.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 500; font-style: normal; font-display: swap; src: url('./fonts/Delight-Medium.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 500; font-style: normal; font-display: swap; src: url('./fonts/Delight-SemiBold.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 700; font-style: normal; font-display: swap; src: url('./fonts/Delight-Bold.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 800; font-style: normal; font-display: swap; src: url('./fonts/Delight-ExtraBold.ttf') format('truetype'); }
+  @font-face { font-family: 'Delight'; font-weight: 900; font-style: normal; font-display: swap; src: url('./fonts/Delight-Black.ttf') format('truetype'); }
+
+  /* ============================================================
+     TOKENS
+     ============================================================ */
+  :root {
+    --bg:        #f5f5f7;
+    --bg-soft:   #ffffff;
+    --text:      #1a1a1e;
+    --muted:     #6b7280;
+    --muted-2:   #9ca3af;
+    --line:      #e5e5ea;
+    --card:      #0a0a10;
+    --card-line: rgba(255,255,255,0.06);
+    --alva:      #49A3A6;
+    --alva-hi:   #5cb9bc;
+    --alva-dim:  rgba(73,163,166,0.18);
+    --orange:    #ff8a4c;
+    --purple:    #b388ff;
+    --gain:      #22c55e;
+    --gain-hi:   #4ade80;
+    --loss:      #ef4444;
+    /* 3.0 round 6 — all three families collapse onto Delight. The
+       --font-display / --font-mono vars are kept (with the same value)
+       so the existing typography rules don't need to be rewritten;
+       they all resolve to Delight at the requested weight. */
+    --font:         "Delight", system-ui, sans-serif;
+    --font-display: "Delight", system-ui, sans-serif;
+    --font-mono:    "Delight", ui-monospace, monospace;
+  }
+
+  *, *::before, *::after { box-sizing: border-box; }
+  html, body { margin: 0; padding: 0; }
+  html { background: var(--bg); scroll-behavior: smooth; }
+
+  /* Balance the wrap on hero-class headings so the last line never ends
+     in a one-word orphan. Zero cost, modern browsers only (Chrome 114+,
+     Safari 17.5+, FF 121+) — older browsers ignore silently. Reference:
+     Vercel / Notion / Anthropic all ship this on their H1s. */
+  h1, h2, .opening h1, .stage-title, .section-head h2, .lb-card h2,
+  .lb-intro-h, .playbook-text h2, .dialog h3, .stage-marquee .stage-title {
+    text-wrap: balance;
+  }
+
+  /* iOS Safari triggers an auto-zoom when an input with font-size < 16px
+     receives focus. The visual jump breaks the modal layout. Force every
+     focusable form control to ≥16px. Reference: Apple HIG, Bootstrap 5
+     ".form-control" baseline. */
+  input, textarea, select { font-size: 16px; }
+
+  /* ============================================================
+     SNAP SCROLL — opening ⇄ stage (first two screens only)
+     The snap-active class is toggled by JS only while the user's
+     viewport is still inside the opening-to-stage range. Once the
+     stage has scrolled fully past, snap is disabled so the rest of
+     the page (leaderboard / agents / etc.) scrolls normally.
