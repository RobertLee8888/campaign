+            // samples hit different alpha values at the card edge;
+            // mix(uBgColor, sample.rgb, sample.a) per channel still
+            // produces the wavelength-shifted fringes the user wants.
+            vec3 cR = mix(uBgColor, sR.rgb, sR.a);
+            vec3 cG = mix(uBgColor, sG.rgb, sG.a);
+            vec3 cB = mix(uBgColor, sB.rgb, sB.a);
+            vec3 rgb = vec3(cR.r, cG.g, cB.b);
+
+            // -- radial edge blur — DoF falloff at corners. The
+            // blur only applies in the outer ring (edge > 0), where
+            // we're already using the mix() composite for CA, so
+            // matching mix() here keeps things consistent. --
+            if (edge > 0.01) {
+              vec2 ofs = uTexel * uEdgeBlur * edge;
+              vec4 blurred = boxSample(uvG, ofs);
+              vec3 blurComp = mix(uBgColor, blurred.rgb, blurred.a);
+              rgb = mix(rgb, blurComp, edge * 0.7);
+            }
+
+            // -- CRT edge color shift (old-TV phosphor vignette) --
+            // Mix toward alva teal #49A3A6 at the corners — the
+            // "周围偏绿" effect the user asked for. Center stays at
+            // pure uBgColor, corners blend up to 35% toward alva teal.
+            // Using mix-toward-color (instead of multiplicative shift)
+            // because mixing white * coolShift just darkens white into
+            // grey, whereas mix(white, teal) actually produces a
+            // saturated mint hue. Combined with the .opening CSS
+            // radial-gradient (white center → mint edges), the visible
+            // vignette is continuous between CSS bg and WebGL pixels.
+            // 3.0 round 26 — edge tint swapped from alva-teal to a
+            // restrained neutral grey (user: "灰色要克制"). Mix toward
+            // #ededf0 ≈ vec3(0.929) so the corners only desaturate
+            // slightly instead of taking on a brand hue.
+            float tintEdge = smoothstep(0.35, 1.15, r2);
+            vec3 neutralGrey = vec3(0.929, 0.929, 0.941); // #ededf0
+            rgb = mix(rgb, neutralGrey, tintEdge * 0.50);
+
+            // -- film grain — radial falloff per user request
+            // (3.0 round 46.18): center clean, edges grainier. Use
+            // the same r² as the CRT vignette; smoothstep from 0.15
+            // to 1.0 gives a gentle ramp — barely any noise within
+            // ~40% of the radius, ramping to full uGrain at the
+            // corners. Keeps the H1 in the center crisp while the
+            // section corners get the old-TV texture. --
+            float grainMask = smoothstep(0.15, 1.0, r2);
+            float grain = rand(gl_FragCoord.xy * 0.5 + vec2(uTime * 13.0, uTime * 17.0)) - 0.5;
+            rgb += vec3(grain) * uGrain * grainMask;
+
+            gl_FragColor = vec4(rgb, 1.0);
+          }
+        `,
+        transparent: true,
+        depthTest: false,
+        depthWrite: false,
+      });
+      const postMesh = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), postMat);
+      postScene.add(postMesh);
+
+      // ----- per-frame size update + render -----
+      const startT = performance.now() / 1000;
+      let lastW = 0, lastH = 0;
+
+      function frame() {
+        requestAnimationFrame(frame);
+        const w = opening.clientWidth;
+        const h = opening.clientHeight;
+        if (w === 0 || h === 0) return;
+
+        if (w !== lastW || h !== lastH) {
+          renderer.setSize(w, h, false);
+          camera.right = w;
+          camera.top   = h;
+          camera.updateProjectionMatrix();
+          ensureRT(Math.round(w * DPR), Math.round(h * DPR));
+          postMat.uniforms.uAspect.value = w / h;
+          postMat.uniforms.uTexel.value.set(
+            1 / Math.round(w * DPR),
+            1 / Math.round(h * DPR)
+          );
+          lastW = w; lastH = h;
+        }
+
+        // Drive each plane's drift. Ghosts and real tweets share the
+        // same -100vw → +100vw motion, just at different durations.
+        const t = performance.now() / 1000 - startT;
+        for (const m of meshes) {
+          const dur   = m.t.durS;
+          const phase = (((t - m.t.d) % dur) + dur) % dur / dur;
+          const xLeft = -w + phase * 2 * w;
+          const yTop  = (m.t.y / 100) * h;
+          // 3.0 round 46.19 — snap plane positions to integer device
+          // pixels so the texture-to-screen mapping is 1:1 without
+          // sub-pixel rasterization. Eliminates the side-to-side
+          // border thickness fluctuation that happens when the
+          // plane edge falls on a non-integer screen position and
+          // the GPU rasterizer distributes the edge over 2-3
+          // destination pixels asymmetrically.
+          m.mesh.position.x = Math.round((xLeft + m.t.w / 2) * DPR) / DPR;
+          m.mesh.position.y = Math.round((h - yTop - m.t.h / 2) * DPR) / DPR;
+        }
+
+        // (a) render scene → render target
+        renderer.setRenderTarget(rt);
+        renderer.setClearColor(0x000000, 0);
+        renderer.clear(true, true, true);
+        renderer.render(scene, camera);
+
+        // (b) render fullscreen post-pass → screen
+        postMat.uniforms.tDiffuse.value = rt.texture;
+        // Advance grain seed each frame so noise rehashes (TV shimmer).
+        postMat.uniforms.uTime.value = t;
+        renderer.setRenderTarget(null);
+        renderer.setClearColor(0x000000, 0);
+        renderer.clear(true, true, true);
+        renderer.render(postScene, postCam);
+      }
+      frame();
+      } catch (err) {
+        console.error('[lens] WebGL init failed — falling back to DOM tweets', err);
+        if (initialized) {
+          // restore visibility so the page isn't blank if the WebGL init
+          // partially completed and then crashed
+          tweetEls.forEach(el => { el.style.visibility = ''; });
+        }
+      }
+    });
+    } // <- close initLens() (round 46.4 wrapper around the IIFE body)
+  })();
+
+  /* ============================================================
+     MOBILE NAV DRAWER — hamburger toggle, ESC, outside-tap, scrollspy
+     ============================================================
+     Wires the .nav-menu-toggle to .nav-drawer's `.open` class with
+     proper a11y (aria-expanded, label swap, focus restore). Also
+     mirrors the scrollspy `.active` state from .nav-tab onto the
+     drawer's matching .nav-drawer-item so the user can see "which
+     section am I on" while the drawer is open. Reference patterns:
+     GitHub mobile (top drawer), Linear iOS (drawer with section
+     items), Vercel mobile (collapsible header). */
+  (function setupNavDrawer() {
+    const toggle = document.getElementById('nav-menu-toggle');
+    const drawer = document.getElementById('nav-drawer');
+    if (!toggle || !drawer) return;
+
+    const openLabel  = 'Open menu';
+    const closeLabel = 'Close menu';
+
+    function open() {
+      drawer.classList.add('open');
+      toggle.setAttribute('aria-expanded', 'true');
+      toggle.setAttribute('aria-label', closeLabel);
+      // Prevent the body from scrolling under the drawer on tiny
+      // viewports — same idiom as the modal-open behaviour.
+      document.documentElement.style.overflow = 'hidden';
+    }
+    function close() {
+      drawer.classList.remove('open');
+      toggle.setAttribute('aria-expanded', 'false');
+      toggle.setAttribute('aria-label', openLabel);
+      document.documentElement.style.overflow = '';
+    }
+    function isOpen() {
+      return drawer.classList.contains('open');
+    }
+
+    // Toggle on hamburger
+    toggle.addEventListener('click', (e) => {
+      e.stopPropagation();
+      isOpen() ? close() : open();
+    });
+
+    // Close when any drawer item is tapped. data-section links route
+    // through the existing scrollspy / smoothScrollTo wiring (the
+    // anchor href is preserved so default behaviour still works);
+    // data-open buttons route through the existing modal opener
+    // (separate global listener). We just need to close the drawer
+    // so the page is visible after the action.
+    drawer.querySelectorAll('.nav-drawer-item, .nav-drawer-action').forEach(el => {
+      el.addEventListener('click', () => {
+        // Tiny defer so the modal opener / smooth scroll have time
+        // to grab the click before the drawer's close transition
+        // changes the layout.
+        setTimeout(close, 60);
+      });
+    });
+
+    // ESC key
+    document.addEventListener('keydown', (e) => {
+      if (e.key === 'Escape' && isOpen()) {
+        close();
+        toggle.focus();
+      }
+    });
+
+    // Outside-tap closes
+    document.addEventListener('click', (e) => {
+      if (!isOpen()) return;
+      if (drawer.contains(e.target) || toggle.contains(e.target)) return;
+      close();
+    });
+
+    // If user resizes from mobile up to desktop while drawer is
+    // open, close it (CSS will hide the toggle but the .open class
+    // would linger).
+    window.matchMedia('(min-width: 761px)').addEventListener?.('change', (e) => {
+      if (e.matches && isOpen()) close();
+    });
+
+    // Scrollspy mirror — when any .nav-tab gains .active, mirror it
+    // onto the matching .nav-drawer-item. The scrollspy code that
+    // sets .nav-tab.active is elsewhere; we observe class changes.
+    const tabs = document.querySelectorAll('.nav-tab[data-section]');
+    const drawerItems = drawer.querySelectorAll('.nav-drawer-item[data-section]');
+    if (tabs.length && drawerItems.length) {
+      const syncActive = () => {
+        let activeSection = null;
+        tabs.forEach(t => { if (t.classList.contains('active')) activeSection = t.dataset.section; });
+        drawerItems.forEach(d => {
+          d.classList.toggle('active', d.dataset.section === activeSection);
+        });
+      };
+      const mo = new MutationObserver(syncActive);
+      tabs.forEach(t => mo.observe(t, { attributes: true, attributeFilter: ['class'] }));
+      syncActive();    // run once on init
+    }
+  })();
+
+  /* ============================================================
+     STICKY BOTTOM CTA — IntersectionObserver wiring
+     ============================================================
+     The bar enters view once the user scrolls past .stage-actions
+     (the hero's second-screen CTA block) and exits view when the
+     footer becomes visible. A session-scoped dismiss flag honours
+     the close button so the bar doesn't keep popping back.
+     Mobile-only: the bar is display:none on desktop via CSS, so the
+     observer is a no-op there but harmless.
+     Reference: Tesla `tcl-permanent-cta` observation, Stripe.com
+     mobile pricing flow. */
+  (function setupStickyCta() {
+    const bar = document.getElementById('stickyCta');
+    if (!bar) return;
+    const isMobile = window.matchMedia('(max-width: 760px)').matches;
+    if (!isMobile) return;                          // PC keeps the bar hidden
+    if (sessionStorage.getItem('stickyCtaDismissed') === '1') {
+      bar.setAttribute('hidden', '');               // user opted out this session
+      return;
+    }
+    bar.removeAttribute('hidden');                  // CSS will reveal as flex
+
+    const heroCta = document.querySelector('.stage-actions') ||
+                    document.querySelector('.opening-arrow');
+    const footer  = document.querySelector('footer.f');
+    if (!heroCta || !footer) return;
+
+    const setVisible = (v) => bar.classList.toggle('visible', v);
+    let pastHero = false;
+    let footerIn = false;
+
+    const ioHero = new IntersectionObserver((entries) => {
+      entries.forEach(e => {
+        pastHero = !e.isIntersecting && e.boundingClientRect.top < 0;
+        setVisible(pastHero && !footerIn);
+      });
+    }, { rootMargin: '-56px 0px 0px 0px' });        // discount the fixed nav
+    ioHero.observe(heroCta);
+
+    const ioFooter = new IntersectionObserver((entries) => {
+      entries.forEach(e => {
+        footerIn = e.isIntersecting;
+        setVisible(pastHero && !footerIn);
+      });
+    });
+    ioFooter.observe(footer);
+
+    // While any modal is open we hide the bar (modal z-index is 80,
+    // bar is 40 — modal wins visually but the bar still steals tap
+    // space at the bottom; hiding feels cleaner).
+    const modalObserver = new MutationObserver(() => {
+      const anyOpen = !!document.querySelector('.modal.open');
+      bar.style.visibility = anyOpen ? 'hidden' : '';
+    });
+    modalObserver.observe(document.body, { attributes: true, subtree: true, attributeFilter: ['class'] });
+
+    bar.querySelector('.sc-close')?.addEventListener('click', () => {
+      bar.classList.remove('visible');
+      sessionStorage.setItem('stickyCtaDismissed', '1');
+      // Tear down after exit transition so the bar can't be re-shown
+      // by the observer mid-session.
+      setTimeout(() => bar.setAttribute('hidden', ''), 320);
+    });
+  })();
+
+  /* ============================================================
+     PLAYBOOK CAROUSEL — dot indicator sync (mobile)
+     ============================================================
+     The Material 3 Hero Carousel pattern needs a visible position
+     indicator. We render a <span class="dot"> per .play-card next to
+     the .play-track and toggle .active on the dot whose card is
+     closest to the track's scroll-center. Cheap math, no library.
+     Skip on desktop where the carousel is replaced by a grid.
+     ============================================================ */
+  /* ============================================================
+     AGENTS / USE CASES — mobile cover injection
+     ============================================================
+     The desktop pin-scroll has the 5 covers in a separate right-
+     column .agents-cards-stage. On mobile we want each cover to
+     sit ON TOP OF its matching tab-item (cover + title + body +
+     CTA stacked as a self-contained card).
+
+     We clone each .agents-card-cover into the matching .agents-
+     tab-item (the original stays in .agents-cards-stage for
+     desktop; the stage itself is hidden on mobile via CSS).
+
+     Re-runs on viewport resize so a desktop→mobile→desktop drag
+     keeps the right cover-placement for each width without orphan
+     clones. Idempotent — checks for a `.mobile-clone` marker so it
+     never injects twice. */
+  (function setupAgentsMobile() {
+    const MQ = '(max-width: 900px)';
+    function sync() {
+      const isMobile = window.matchMedia(MQ).matches;
+      const tabs = document.querySelectorAll('.agents-tab-item');
+      const cards = document.querySelectorAll('.agents-cards-stage .agents-card');
+      if (!tabs.length) return;
+      tabs.forEach((tab, i) => {
+        const existing = tab.querySelector('.agents-card-cover.mobile-clone');
+        if (isMobile) {
+          if (existing) return;                          // already injected
+          const srcCover = cards[i]?.querySelector('.agents-card-cover');
+          if (!srcCover) return;
+          const clone = srcCover.cloneNode(true);
+          clone.classList.add('mobile-clone');
+          // Strip any data-attrs / ids that the desktop pin-scroll
+          // JS might re-query (avoid duplicate-id selectors).
+          clone.removeAttribute('id');
+          tab.insertBefore(clone, tab.firstChild);
+        } else if (existing) {
+          existing.remove();                             // restore desktop
+        }
+      });
+    }
+    sync();
+    window.matchMedia(MQ).addEventListener?.('change', sync);
+  })();
+
+  (function setupPlayDots() {
+    const isMobile = window.matchMedia('(max-width: 760px)').matches;
+    if (!isMobile) return;
+    const track = document.getElementById('play-track');
+    if (!track) return;
+    const cards = track.querySelectorAll('.play-card');
+    if (cards.length < 2) return;
+
+    // Build dots if they aren't in the markup already
+    let dotsEl = track.parentElement.querySelector('.play-dots');
+    if (!dotsEl) {
+      dotsEl = document.createElement('div');
+      dotsEl.className = 'play-dots';
+      cards.forEach((_, i) => {
+        const d = document.createElement('span');
+        d.className = 'dot' + (i === 0 ? ' active' : '');
+        dotsEl.appendChild(d);
+      });
+      track.parentElement.appendChild(dotsEl);
+    }
+    const dots = dotsEl.querySelectorAll('.dot');
+
+    let raf = 0;
+    const onScroll = () => {
+      if (raf) return;
+      raf = requestAnimationFrame(() => {
+        raf = 0;
+        const center = track.scrollLeft + track.clientWidth / 2;
+        let closest = 0, closestDist = Infinity;
+        cards.forEach((card, i) => {
+          const cardCenter = card.offsetLeft + card.offsetWidth / 2;
+          const d = Math.abs(cardCenter - center);
+          if (d < closestDist) { closestDist = d; closest = i; }
+        });
+        dots.forEach((d, i) => d.classList.toggle('active', i === closest));
+      });
+    };
+    track.addEventListener('scroll', onScroll, { passive: true });
+  })();
+
+  /* ============================================================
+     USE CASES PIN-SCROLL CONTROLLER  (3.0 round 13)
+     #agents is 600vh tall; .agents-pin sticks at top:64px across that
+     full range. As section's getBoundingClientRect().top moves from
+     0 (sticky engages) to -(sectionH - viewportH) (sticky releases),
+     we map that progress to a card index 0..(N-1) and translateX the
+     .agents-track to show the active card.
+     Mobile: disabled (CSS collapses to static stack).
+     ============================================================ */
+  (() => {
+    const section = document.getElementById('agents');
+    if (!section) return;
+    const track = document.getElementById('agents-track');
+    // 3.0 round 19 — tabs restructured: each tab is now a .agents-tab-item
+    // wrapper containing a title button + a detail block (subtitle + CTA).
+    // Active state is now toggled on the WRAPPER so CSS can drive both
+    // title color and detail visibility from a single class.
+    const items = section.querySelectorAll('.agents-tab-item');
+    const buttons = section.querySelectorAll('.agents-tab-v');
+    const cards = section.querySelectorAll('.agents-card');
+    const N = cards.length;
+    if (!track || !N) return;
+
+    const isMobile = () => window.matchMedia('(max-width: 900px)').matches;
+
+    let lastIdx = -1;
+    let raf = 0;
+
+    function update() {
+      raf = 0;
+      if (isMobile()) {
+        track.style.transform = '';
+        return;
+      }
+      const rect = section.getBoundingClientRect();
+      const total = Math.max(1, section.offsetHeight - window.innerHeight);
+      const p = Math.max(0, Math.min(0.999999, -rect.top / total));
+      const idx = Math.min(N - 1, Math.floor(p * N));
+      if (idx !== lastIdx) {
+        // Vertical-stack carousel — translateY in PIXELS so that the
+        // active card sits VERTICALLY CENTERED in the stage and the
+        // previous/next cards peek above/below (clipped by the pin).
+        // Measure on each switch so layout changes (resize, font load)
+        // don't desync the offset.
+        const stage = track.parentElement;
+        const cardH = cards[0].offsetHeight;
+        const gap = parseFloat(getComputedStyle(track).rowGap || '40') || 40;
+        const stageH = stage.offsetHeight;
+        const offset = (stageH - cardH) / 2 - idx * (cardH + gap);
+        track.style.transform = 'translateY(' + Math.round(offset) + 'px)';
+        items.forEach((t, i) => t.classList.toggle('active', i === idx));
+        lastIdx = idx;
+      }
+    }
+
+    function schedule() {
+      if (raf) return;
+      raf = requestAnimationFrame(update);
+    }
+
+    window.addEventListener('scroll', schedule, { passive: true });
+    window.addEventListener('resize', () => {
+      // Force re-compute (stageH / cardH may have changed)
+      lastIdx = -1;
+      schedule();
+    });
+    schedule();
+
+    // Tab click → smooth scroll to the matching slice center.
+    // The click target is the title button; we use its index to seek.
+    buttons.forEach((btn, i) => {
+      btn.addEventListener('click', () => {
+        if (isMobile()) {
+          // On mobile the cards are all visible in a stack; scroll to
+          // the matching card directly.
+          cards[i].scrollIntoView({ behavior: 'smooth', block: 'start' });
+          return;
+        }
+        const sectionTop = section.getBoundingClientRect().top + window.scrollY;
+        const total = section.offsetHeight - window.innerHeight;
+        const sliceCenter = (i + 0.5) / N;
+        window.scrollTo({ top: sectionTop + sliceCenter * total, behavior: 'smooth' });
+      });
+    });
+  })();
+
+</script>
+
+</body>
+</html>
