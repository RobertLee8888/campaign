+│   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ │  ← 36px gap
+│                                         │
+│  ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓ │  ← 下一个 use case cover
+│  ▓             📈                    ▓ │     (dark variant)
