+    overflow: hidden;
+    max-height: 0;
+    opacity: 0;
+    transform: translateY(-4px);
+    transition: max-height .35s ease, opacity .25s ease, transform .25s ease, padding .3s ease;
+    display: flex;
+    flex-direction: column;
+    gap: 16px;
