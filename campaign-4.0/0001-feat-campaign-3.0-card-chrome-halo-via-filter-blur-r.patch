+    color: var(--alva);
+    font-weight: 600;
+  }
+  /* 3.0 round 24 — active card: brand-teal tint only, no shadow.
+     User flagged shadow as unwanted; the bg-color difference between
+     neutral grey (inactive) and brand teal (active) already carries
+     enough hierarchy. Cleaner, flatter look. */
+  .agents-tab-item.active {
+    background: rgba(73, 163, 166, 0.10);
+  }
+  /* Detail block (subtitle + CTA) — collapsed by default, expanded when
+     parent .agents-tab-item is .active. max-height animation gives a
+     gentle expand/collapse without layout-jank when the active tab
+     changes during scroll-lock progression. */
