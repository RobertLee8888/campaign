+    display: block;
+  }
+  /* 2-col grid: left sidebar (heading + tabs) + right card stage.
+     3.0 round 15 — left rail widened 380 → 480 (heading at display-l
+     wraps cleanly here, tabs in card style have room). Border between
+     columns removed since each tab is now its own card. */
