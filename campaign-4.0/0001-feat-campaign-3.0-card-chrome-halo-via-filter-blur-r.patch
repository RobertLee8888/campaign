+  .agents-tab-item.active .agents-tab-detail {
+    max-height: 280px;
+    opacity: 1;
+    transform: translateY(0);
+    padding: 12px 0 4px;
+  }
+  .agents-tab-detail p {
+    margin: 0;
+    color: var(--muted);
+    font-family: var(--font);
+    font-weight: 400;
+    font-size: 15px;
+    line-height: 1.55;
+    max-width: 440px;
+  }
+  .agents-tab-cta {
+    display: inline-flex;
+    align-items: center;
+    gap: 8px;
+    align-self: flex-start;
+    padding: 12px 24px;
+    border-radius: 999px;
+    background: var(--text);
+    color: #fff;
+    text-decoration: none;
+    font-family: var(--font);
+    font-size: 14px;
+    font-weight: 500;
+    transition: background .15s, transform .15s;
+  }
+  .agents-tab-cta:hover { background: var(--alva); transform: translateY(-1px); }
+
+  /* Right column window — vertical-stack carousel.
+     3.0 round 14 — stage overflow flipped to visible so adjacent
+     cards bleed BEYOND the stage box. The pin's own overflow:hidden
+     (top: just-below-nav, bottom: section.bottom) is what does the
+     final clip — so the prev/next cards get cut by the SECTION
+     edges, not by a tighter inner container. */
+  .agents-cards-stage {
+    position: relative;
+    min-width: 0;
+    min-height: 0;
+    overflow: visible;
+  }
+  .agents-track {
+    display: flex;
+    flex-direction: column;
+    /* 3.0 round 24 — gap pulled in 80 → 32 so adjacent cards sit
+       close, reading as a tight vertical reel. */
+    gap: 32px;
+    /* Track is taller than stage; JS sets translateY in PIXELS to
+       center the active card within stage (so card[0] starts
+       vertically centered, not flush with top). */
+    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
+    will-change: transform;
+  }
+  .agents-card {
+    flex: 0 0 auto;
+    /* 3.0 round 24 — card proportionally scaled up. max-width 620 →
+       760 so the cover fills more of the right column and reads as
+       the section's hero element. 3:2 aspect ratio preserved (cover
+       inside still uses aspect-ratio: 3/2). Right-aligned via
+       margin-left:auto so the card's right edge still matches the
+       leaderboard's right edge. */
+    width: 100%;
+    max-width: 760px;
+    margin: 0 0 0 auto;
+    display: block;
+    padding-right: 0;
+  }
+  .agents-card-cover {
+    /* 3:2 banner — matches the original card cover ratio so the cover
+       reads as a wide product hero, not a tall poster. */
+    aspect-ratio: 3 / 2;
+    border-radius: 12px;
+    display: grid;
+    place-items: center;
+    position: relative;
+    color: #fff;
+    overflow: hidden;
+  }
+  .agents-card-cover::before {
+    content: '';
+    position: absolute; inset: 0;
+    background-image: radial-gradient(rgba(255,255,255,0.18) 1px, transparent 1.5px);
+    background-size: 18px 18px;
+    opacity: 0.45;
+  }
+  .agents-card-cover i {
+    position: relative;
+    z-index: 1;
+    font-size: 104px;
+    filter: drop-shadow(0 10px 28px rgba(0,0,0,0.22));
+  }
+  .agents-card-cover[data-variant="teal"]   { background: linear-gradient(135deg, #49A3A6 0%, #5cb9bc 60%, #2f7a7d 100%); }
+  .agents-card-cover[data-variant="dark"]   { background: linear-gradient(135deg, #1a1a1e 0%, #0a0a10 65%, #000 100%); }
+  .agents-card-cover[data-variant="warm"]   { background: linear-gradient(135deg, #ff8a4c 0%, #ff6f3a 55%, #c84c1f 100%); }
+  .agents-card-cover[data-variant="purple"] { background: linear-gradient(135deg, #b388ff 0%, #8a5cf2 60%, #5b2bb8 100%); }
+
+  /* (3.0 round 19 — .agents-card-body / .agents-card-cta removed; the
+     subtitle + CTA now live in the left column under each tab title,
+     not in the right-column card. The card is just the visual cover.) */
+
+  /* Mobile fallback — pin doesn't make sense on narrow screens; the
+     section collapses to a static stack. 3.0 round 19 — since each tab
+     now carries its own detail (subtitle + CTA), and the right-column
+     cards only carry the visual cover, mobile shows ALL tab items as
+     "open" (every detail visible) and all card covers stacked beneath.
+     Reading order: tab title + subtitle + CTA list on top, card covers
+     after — the cover is then a visual recap of each use case. */
