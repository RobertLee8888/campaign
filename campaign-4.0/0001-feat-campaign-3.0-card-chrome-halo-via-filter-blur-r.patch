+  /* 3.0 round 22 — tab item style retuned per user: inactive becomes
+     gray-bg with NO border; active becomes white-bg (no border) so the
+     visual hierarchy is "neutral grey wash" → "lifted white card". The
+     bg contrast alone carries the active/inactive signal — no
+     competing border weight needed.
+       inactive: rgba(10,10,16,0.04) — soft grey wash
+       active:   var(--bg-soft) (pure white) — pops against the grey */
+  .agents-tab-item {
+    display: flex;
+    flex-direction: column;
+    gap: 0;
+    background: rgba(10, 10, 16, 0.04);
+    border: 0;
+    border-radius: 14px;
+    padding: 14px 22px;
+    transition: background .2s;
+  }
+  .agents-tab-item:hover {
+    background: rgba(10, 10, 16, 0.07);
+  }
+  .agents-tab-v {
+    position: relative;
+    padding: 0;
+    border: 0;
+    background: transparent;
+    text-align: left;
+    font-family: var(--font);
+    font-size: 18px;
+    font-weight: 500;
+    line-height: 1.3;
+    color: var(--muted);
+    cursor: pointer;
+    transition: color .2s;
+    white-space: normal;
+  }
+  .agents-tab-v:hover {
+    color: var(--text);
+  }
+  /* Active title: brand-teal. Card bg stays white; the bg distinction
+     comes from the EXPANDED detail block beneath the title. */
