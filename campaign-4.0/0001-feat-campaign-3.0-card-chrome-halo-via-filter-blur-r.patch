+    gap: 44px;
+  }
+  .agents-side {
+    display: flex;
+    flex-direction: column;
+    /* 3.0 round 17 — content vertically centered in the side rail
+       so heading + tabs sit as a single block, equal top/bottom
+       breathing room (instead of glued to the top). */
