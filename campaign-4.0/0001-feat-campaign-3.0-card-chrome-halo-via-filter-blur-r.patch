+    top: 0;
+    height: 100vh;
+    width: 100%;
     overflow: hidden;
     background: var(--bg-soft);
   }
+  .agents-pin-inner {
+    width: 100%;
+    max-width: 1320px;
+    height: 100%;
+    margin: 0 auto;
+    /* 3.0 round 21 — padding-top raised to clear the 64px fixed nav
+       PLUS give the H2 visual breathing room. Bottom padding kept at
+       56 for the cards' base margin. Horizontal 16 matches the
+       section-wrap. */
